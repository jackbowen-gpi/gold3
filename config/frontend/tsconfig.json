{
  "compilerOptions": {
    "outDir": "build",
    "module": "esnext",
    "target": "ES2021",

    "allowJs": true,
    "baseUrl": "../../",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "noEmit": true,
    
    "skipLibCheck": true,
    "strict": true,
    "types": ["node", "jest", "@testing-library/jest-dom"]
  },
  "include": ["../../frontend/**/*"],
  "exclude": ["node_modules", "build"]
}
