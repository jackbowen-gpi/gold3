{
  "compilerOptions": {
    "target": "es2022",
    "module": "node18",
    "lib": ["es2022"],
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist",
  "rootDir": ".",
    "noEmit": false
  },
  "include": ["src", "backend", "frontend/**/*", "**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "dist", "config"]
}