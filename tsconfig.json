{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
  "types": ["jest", "@testing-library/jest-dom"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "frontend/js/**/*",
    "frontend/assets/**/*",
    "openapi-ts.config.ts",
    "config/frontend/**/*"
  ]
}