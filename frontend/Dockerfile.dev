# Development Dockerfile for frontend
FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Install Chromium and libs required by Puppeteer in Alpine
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    font-noto \
    wget

ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV CHROME_BIN=/usr/bin/chromium-browser

# Copy configuration
COPY config/frontend/ ./config/frontend/

# Create symlinks for backward compatibility
RUN ln -sf config/frontend/tsconfig.json . && \
    ln -sf config/frontend/jest.config.js . && \
    ln -sf config/frontend/eslint.config.js .eslintrc.js

# Copy source code
COPY frontend/ ./frontend/
COPY webpack.config.js ./

# Expose port
EXPOSE 3000

# Default command
CMD ["npm", "run", "dev"]