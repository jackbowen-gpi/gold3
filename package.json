{
  "name": "gold3-frontend",
  "version": "0.0.1",
  "private": true,
  "description": "gold3 frontend.",
  "engines": {
    "node": ">=20 <21"
  },
  "browserslist": "> 0.25%, not dead",
  "main": "frontend/js/index.tsx",
  "scripts": {
    "test": "jest",
    "test:watch": "npm test -- --watch",
    "test:update": "npm test -- --u",
    "dev": "webpack serve --mode=development --hot",
    "build": "NODE_ENV=production tsc && webpack --progress --bail --mode=production",
    "smoke": "node scripts/puppeteer_smoke.js",
    "smoke:docker": "docker run --rm -e SMOKE_URL=http://host.docker.internal:8000 -v %CD%:/workspace -w /workspace node:20-bullseye sh -c \"apt-get update -qq && apt-get install -y -qq chromium && npm install puppeteer@24.17.0 --no-audit --no-fund >/dev/null 2>&1 && node scripts/puppeteer_smoke.js\"",
    "smoke:ci": "npm run smoke:docker",
    "lint": "eslint \"frontend/src/**/*.{ts,tsx}\" --ignore-pattern 'frontend/webpack_bundles/**' --ignore-pattern 'frontend/**/*.map' --max-warnings=0",
    "tsc": "tsc -p ./tsconfig.json --noEmit",
    "coverage": "jest --coverage",
    "openapi-ts": "openapi-ts"
  },

  "checkScripts": {
    "check:ts:root": "npx tsc -p ./tsconfig.json --noEmit",
    "check:ts:frontend": "npx tsc -p ./config/frontend/tsconfig.json --noEmit",
    "check:deps": "npm ci --prefer-offline --no-audit",
    "check:lint": "npm run lint && ./.venv/Scripts/ruff.exe check --quiet backend || ruff check --quiet backend",
    "check:all": "npm run check:deps && npm run check:ts:root && npm run check:ts:frontend && npm run check:lint && npm test -- --silent"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx,js,jsx}": [
      "npm run lint -- --fix",
      "git add"
    ]
  },
  "prepare": "husky install",
  "dependencies": {
    "@hey-api/openapi-ts": "^0.45.0",
    "@sentry/browser": "^8.55.0",
    "@sentry/react": "^8.55.0",
    "axios": "^1.11.0",
    "bootstrap": "~5.3.3",
    "classnames": "~2.5.1",
    "cookie": "^1.0.2",
    "lodash": "~4.17.21",
    "marked": "~12.0.2",
    "puppeteer": "^24.17.0",
    "python": "^0.0.4",
    "react": "19.1.1",
    "react-bootstrap": "~2.10.2",
    "react-dom": "19.1.1",
    "react-icons": "^5.5.0",
    "react-router": "~6.23.1"
  },
  "devDependencies": {
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.13",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.5.6",
    "@swc/jest": "^0.2.36",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "~6.4.5",
    "@testing-library/react": "~16.3.0",
    "@testing-library/user-event": "~14.5.2",
    "@types/cookie": "^0.6.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "ajv": "~8.13.0",
    "circular-dependency-plugin": "~5.2.2",
    "css-loader": "~7.1.1",
    "eslint": "~8.57.0",
    "eslint-config-vinta": "github:vintasoftware/eslint-config-vinta#main",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-import-resolver-webpack": "~0.13.8",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-es": "^4.1.0",
    "eslint-plugin-import": "~2.29.1",
    "eslint-plugin-jest": "~27.9.0",
    "eslint-plugin-jsx-a11y": "~6.8.0",
    "eslint-plugin-prettier": "~5.1.3",
    "eslint-plugin-promise": "~6.1.1",
    "eslint-plugin-react": "~7.34.1",
    "eslint-plugin-react-hooks": "~4.6.2",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-sonarjs": "~0.23.0",
    "eslint-plugin-unicorn": "~49.0.0",
    "identity-obj-proxy": "~3.0.0",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "jest-transform-stub": "^2.0.0",
    "mini-css-extract-plugin": "~2.9.0",
    "postcss": "~8.4.38",
    "postcss-loader": "~8.1.1",
    "prettier": "~3.2.5",
    "react-refresh": "^0.14.2",
    "sass": "1.77.6",
    "sass-loader": "~14.2.1",
    "style-loader": "~4.0.0",
    "swc-loader": "^0.2.6",
    "typescript": "^5.9.2",
    "webpack": "^5.101.3",
    "webpack-bundle-tracker": "~3.1.0",
    "webpack-cli": "~5.1.4",
    "webpack-dev-server": "^5.2.2",
    "whatwg-fetch": "~3.6.20"
  }
}
